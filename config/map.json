{
  "pipeline": {
    "default_max_duration_hours": 5.0,
    "decision_timeout_seconds": 1800.0,
    "auto_continue": false
  },
  "models": {
    "default_strategy": "synthetic",
    "default_model": "glm-5.1",
    "max_tokens": 4096,
    "temperature": 0.7,
    "timeout": 120,
    "routing": {
      "glm-5.1": "http",
      "glm-4-plus": "http",
      "task:analyze": "http",
      "task:plan": "http",
      "task:review": "http",
      "task:implement": "http",
      "task:debug": "http"
    },
    "fallback_chain": ["http", "opencode", "synthetic"],
    "strategies": {
      "http": {
        "enabled": false,
        "api_key": "",
        "api_base": "https://open.bigmodel.cn/api/paas/v4",
        "default_model": "glm-5.1",
        "timeout": 120
      },
      "opencode": {
        "enabled": false
      },
      "synthetic": {
        "enabled": true,
        "enable_test_runner": true
      }
    }
  },
  "model_request_retry": {
    "max_retries": 5,
    "base_delay_seconds": 5,
    "max_delay_seconds": 120
  },
  "watchdog": {
    "enabled": true,
    "check_interval_seconds": 30.0,
    "task_stall_threshold_seconds": 1800.0,
    "session_idle_threshold_seconds": 7200.0,
    "progress_stall_threshold_seconds": 3600.0,
    "auto_recover": false,
    "max_auto_recover_attempts": 2,
    "auto_retry_stalled_tasks": true,
    "auto_retry_idle_model_request": true,
    "model_request_retry_max_attempts": 10,
    "model_request_retry_cooldown_seconds": 60.0,
    "model_request_retry_reason": "watchdog_session_idle"
  },
  "parallel_executor": {
    "timeout_per_task": 600.0
  }
}
